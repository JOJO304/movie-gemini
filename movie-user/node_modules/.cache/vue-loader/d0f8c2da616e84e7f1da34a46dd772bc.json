{"remainingRequest":"E:\\endMovie\\movie-user\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\endMovie\\movie-user\\src\\components\\movie\\movie-item.vue?vue&type=style&index=0&id=84d23742&scoped=true&lang=css&","dependencies":[{"path":"E:\\endMovie\\movie-user\\src\\components\\movie\\movie-item.vue","mtime":1772347829936},{"path":"E:\\endMovie\\movie-user\\node_modules\\css-loader\\dist\\cjs.js","mtime":499162500000},{"path":"E:\\endMovie\\movie-user\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":499162500000},{"path":"E:\\endMovie\\movie-user\\node_modules\\postcss-loader\\src\\index.js","mtime":499162500000},{"path":"E:\\endMovie\\movie-user\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"E:\\endMovie\\movie-user\\node_modules\\vue-loader\\lib\\index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["movie-item.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA0FA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA","file":"movie-item.vue","sourceRoot":"src/components/movie","sourcesContent":["<template>\n  <div class=\"movie-item\">\n    <div v-on:mouseover=\"isHover = true\" v-on:mouseleave=\"isHover = false\">\n      <a :href=\"movieInfoUrl\">\n        <img class=\"poster\" :src=\"getPosterUrl()\" alt=\"电影海报\">\n      </a>\n      <div class=\"movie-item-hover\" v-if=\"isHover\">\n        <a :href=\"movieInfoUrl\">\n          <img class=\"poster-hover\" :src=\"getPosterUrl()\" alt=\"电影海报\">\n          <div class=\"movie-hover-info\">\n            <div class=\"title-hover\">\n              <span class=\"name-tags\">{{movieItem.movieName || '未知影片'}}</span>\n            </div>\n            <div class=\"title-hover\">\n              <span class=\"name-tags\">类型: </span>{{formatCategory()}}\n            </div>\n            <div class=\"title-hover\">\n              <span class=\"name-tags\">上映时间: </span>{{formatDate()}}\n            </div>\n          </div>\n        </a>\n      </div>\n    </div>\n    <div class=\"title-style\">\n      <a :href=\"movieInfoUrl\">{{movieItem.movieName || '未知影片'}}</a>\n    </div>\n  </div>\n</template>\n\n<script>\nimport moment from 'moment'\nexport default {\n  name: \"movie-item\",\n  props: {\n    movieItem: {\n      type: Object,\n      default: () => ({})\n    }\n  },\n  data() {\n    return {\n      isHover: false,\n      movieInfoUrl: '',\n      baseUrl: 'http://localhost:8181'\n    }\n  },\n  created(){\n    this.movieInfoUrl = this.movieItem.movieId ? `/movieInfo/${this.movieItem.movieId}` : '#';\n  },\n  methods: {\n    getPosterUrl() {\n      try {\n        if (!this.movieItem.moviePoster) return '';\n        const posterList = JSON.parse(this.movieItem.moviePoster);\n        const poster = Array.isArray(posterList) ? posterList[0] : posterList;\n        return poster ? `${this.baseUrl}${poster}` : '';\n      } catch (e) {\n        console.error('解析海报路径失败:', e);\n        return '';\n      }\n    },\n    formatCategory() {\n      try {\n        if (!this.movieItem.movieCategoryList) return '未知类型';\n        return this.movieItem.movieCategoryList.map(obj => obj.movieCategoryName).join(\"/\");\n      } catch (e) {\n        return '未知类型';\n      }\n    },\n    formatDate() {\n      try {\n        if (!this.movieItem.releaseDate) return '未知时间';\n        return moment(this.movieItem.releaseDate).format('YYYY-MM-DD');\n      } catch (e) {\n        return '未知时间';\n      }\n    }\n  },\n  watch: {\n    'movieItem': {\n      immediate: true,\n      handler() {\n        this.movieInfoUrl = this.movieItem.movieId ? `/movieInfo/${this.movieItem.movieId}` : '#';\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.movie-item{\n  margin-top: 30px;\n  margin-left: 30px;\n  display: inline-block;\n  vertical-align: top;\n  position: relative;\n}\n\n.poster{\n  width: 160px;\n  height: 220px;\n  background: #f5f5f5;\n}\n\n.title-style{\n  width: 160px;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  text-align: center;\n  font-size: 16px;\n  color: #333;\n  margin-top: 10px;\n}\n\n.score{\n  color: #ffb400;\n  font-size: 24px;\n  font-style: italic;\n}\n\na{\n  text-decoration: none;\n  color: #333;\n}\n\n.movie-item-hover{\n  position: absolute;\n  width: 218px;\n  height: 300px;\n  z-index: 10;\n  top: -40px;\n  left: -29px;\n  overflow: hidden;\n  background: #fff;\n  box-shadow: 0 0 16px #fff, 0 0 6px rgba(0,0,0,.2);\n}\n\n.poster-hover{\n  width: 218px;\n  height: 300px;\n  background: #f5f5f5;\n}\n\n.movie-hover-info{\n  padding: 16px;\n  height: 150px;\n  box-sizing: border-box;\n  position: absolute;\n  z-index: 11;\n  top: 150px;\n  background: #fff;\n  width: 218px;\n  color: #999;\n}\n\n.title-hover:first-child{\n  font-size: 20px;\n  line-height: 20px;\n  margin-top: 6px;\n}\n\n.title-hover{\n  font-size: 16px;\n  line-height: 16px;\n  margin-top: 12px;\n  width: 100%;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.name-tags{\n  color: #333;\n}\n</style>"]}]}